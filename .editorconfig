# EditorConfig - https://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,yml,yaml,webmanifest}]
indent_size = 2

[*.{razor,cshtml}]
indent_size = 4

[*.{css,js,html}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.sln]
indent_style = tab
