@inject NotificationService NotificationService

<RadzenCard class="my-4">
    <RadzenText TextStyle="TextStyle.H6" Text="Upload Edmx File" />
    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary rz-mb-2">
        Accepted formats: .edmx, .xml, .csdl (max 50 MB)
    </RadzenText>
    <InputFile OnChange="@SingleUpload" accept=".edmx,.xml,.csdl" />
</RadzenCard>

@code {
    [Parameter]
    public string? XmlData { get; set; }

    [Parameter]
    public EventCallback<string?> XmlDataChanged { get; set; }

    private const long MaxFileSize = 50 * 1024 * 1024; // 50 MB

    private async Task SingleUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file.Size > MaxFileSize)
        {
            NotificationService.Notify(NotificationSeverity.Error, "File Too Large",
                $"Maximum file size is 50 MB. Your file is {file.Size / (1024 * 1024)} MB.");
            return;
        }

        if (!IsValidExtension(file.Name))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Invalid File Type",
                "Please upload a .edmx, .xml, or .csdl file.");
            return;
        }

        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(MaxFileSize).CopyToAsync(ms);
            var byteArray = ms.ToArray();
            XmlData = System.Text.Encoding.UTF8.GetString(byteArray);
            NotificationService.Notify(NotificationSeverity.Success, "Upload Successful",
                $"File \"{file.Name}\" uploaded successfully ({file.Size / 1024} KB).");
            await XmlDataChanged.InvokeAsync(XmlData);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Upload Failed",
                $"Error reading file: {ex.Message}");
        }
    }

    private static bool IsValidExtension(string fileName)
    {
        var extension = Path.GetExtension(fileName);
        return extension.Equals(".edmx", StringComparison.OrdinalIgnoreCase) ||
               extension.Equals(".xml", StringComparison.OrdinalIgnoreCase) ||
               extension.Equals(".csdl", StringComparison.OrdinalIgnoreCase);
    }
}
