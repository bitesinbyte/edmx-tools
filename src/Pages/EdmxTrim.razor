@page "/Trim"
@inject IJSRuntime JSRuntime
@inject NotificationService NotificationService

<PageTitle>bitesinbyte | Edmx Tools | Edmx Trimmer</PageTitle>

<RadzenText TextStyle="TextStyle.H4" Text="Edmx Trimmer" />
<Upload @bind-XmlData=XmlData />
<RadzenSteps @bind-SelectedIndex="@selectedIndex" ShowStepsButtons="false">
    <Steps>
        <RadzenStepsItem Text="Choose Entities">
            <RadzenCard class="my-4">
                <div class="rz-p-sm-12 rz-text-align-center">
                    <RadzenLabel Text="Select Entity" Component="DropDownVirtualization"
                        Style="margin-right: 8px; vertical-align: middle;" />
                    <RadzenDropDown AllowClear="true" AllowVirtualization="true" @bind-Value=entity
                        Name="DropDownVirtualization" AllowFiltering="true" Data=@availableEntities
                        SelectedItemChanged="@OnSelectedEntityChange" Style="width: 100%; max-width: 400px;" />
                </div>

                @foreach (var selectedEntity in selectedEntities)
                {
                    <RadzenButton ButtonStyle="ButtonStyle.Secondary" Shade="Shade.Lighter" class="rz-shadow-0"
                        id="@selectedEntity" Click="@(_ => HandleBadgeClose(selectedEntity))">
                        @selectedEntity
                        <RadzenBadge Shade="Shade.Lighter" BadgeStyle="BadgeStyle.Primary" IsPill="true" Text="X" />
                    </RadzenButton>
                }
                <RadzenStack Orientation="Orientation.Horizontal" Wrap="FlexWrap.Wrap"
                    JustifyContent="JustifyContent.Center" Gap="2rem">

                    <div class="rz-p-12 rz-text-align-center">
                        <RadzenCheckBox @bind-Value=@ExcludeSelected Name="ExcludeSelected" />
                        <RadzenLabel Text="Exclude Selected" Component="ExcludeSelected"
                            Style="margin-left: 8px; vertical-align: middle;" />
                        <RadzenButton Click="@HandleTrim" Disabled="@(!selectedEntities.Any())">
                            Trim
                        </RadzenButton>
                    </div>
                </RadzenStack>
            </RadzenCard>
        </RadzenStepsItem>
        <RadzenStepsItem Text="Download">
            <RadzenCard class="my-4">
                <RadzenButton Click="@DownloadTrimXmlFile" Text="Download" />
            </RadzenCard>
        </RadzenStepsItem>
    </Steps>
</RadzenSteps>

@code {
    private string? XmlData;
    private int selectedIndex;
    private List<string> allEntities = new();
    private List<string> selectedEntities = new();
    private string entity = string.Empty;
    private bool ExcludeSelected;
    private string trimmedXmlData = string.Empty;

    private List<string> availableEntities => allEntities
        .Where(e => !selectedEntities.Contains(e, StringComparer.OrdinalIgnoreCase))
        .OrderBy(e => e)
        .ToList();

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(XmlData))
        {
            try
            {
                allEntities = Helpers.XmlHelpers.GetAllEntities(XmlData);
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Parse Error",
                    $"Failed to parse EDMX file: {ex.Message}");
                allEntities = new();
            }
        }
        else
        {
            allEntities = new();
        }

        selectedEntities = new();
        trimmedXmlData = string.Empty;
        selectedIndex = 0;
    }

    void OnSelectedEntityChange(object args)
    {
        if (args is not string selected) return;

        entity = selected;

        if (!selectedEntities.Contains(entity, StringComparer.OrdinalIgnoreCase) &&
            allEntities.Contains(entity, StringComparer.OrdinalIgnoreCase))
        {
            selectedEntities.Add(entity);
            entity = string.Empty;
        }
    }

    void HandleBadgeClose(string entityToRemove)
    {
        selectedEntities.Remove(entityToRemove);
    }

    void HandleTrim()
    {
        if (string.IsNullOrEmpty(XmlData) || !selectedEntities.Any())
        {
            NotificationService.Notify(NotificationSeverity.Warning, "No Selection",
                "Please select at least one entity.");
            return;
        }

        try
        {
            trimmedXmlData = Helpers.XmlHelpers.Trim(XmlData, selectedEntities, ExcludeSelected);
            selectedIndex = 1;
            NotificationService.Notify(NotificationSeverity.Success, "Trim Complete",
                "EDMX file trimmed successfully.");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Trim Failed",
                $"Error: {ex.Message}");
        }
    }

    async Task DownloadTrimXmlFile()
    {
        var byteArray = System.Text.Encoding.UTF8.GetBytes(trimmedXmlData);
        var stream = new MemoryStream(byteArray);
        var fileName = "trimmedMetadata.xml";

        using var streamRef = new DotNetStreamReference(stream: stream);
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
    }
}
